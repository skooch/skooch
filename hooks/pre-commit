#!/bin/sh
# Pre-commit hook: run shellcheck, lint checks, and tests
# These are zsh files checked with -s bash. We exclude:
#   SC1036,SC1058,SC1071,SC1072,SC1073,SC1087 - zsh syntax (glob qualifiers, array syntax)
#   SC1083                                     - literal braces false-positive (e.g. git @{u} refspec)
#   SC1090,SC1091 - can't follow sourced files
#   SC2034,SC2066,SC2128,SC2154 - zsh variables and array expansion (e.g. ${(@k)array})
#   SC2076                      - quoted =~ regex (intentional in zsh)
#   SC2155,SC2168,SC2181        - style / zsh-valid constructs (local at file scope)
#   SC2206,SC2296,SC3010,SC3030,SC3054 - zsh-specific features

EXCLUDES="SC1036,SC1058,SC1071,SC1072,SC1073,SC1083,SC1087,SC1090,SC1091,SC2034,SC2066,SC2076,SC2128,SC2154,SC2155,SC2168,SC2181,SC2206,SC2296,SC3010,SC3030,SC3054"

errors=0

for f in functions/*.sh lib/profile/*.sh; do
    if [ -f "$f" ]; then
        if ! shellcheck -s bash -S warning -e "$EXCLUDES" "$f" 2>/dev/null; then
            errors=1
        fi
    fi
done

for f in .zshenv .zprofile .zshrc; do
    if [ -f "$f" ]; then
        if ! shellcheck -s bash -S warning -e "$EXCLUDES" "$f" 2>/dev/null; then
            errors=1
        fi
    fi
done

# Check for `local` declarations of zsh special tied variables.
# In zsh, path/fpath/manpath/cdpath are arrays tied to their uppercase counterparts
# (PATH, FPATH, etc.). Using `local path` shadows the tie and corrupts the exported
# variable when the function exits.
ZSH_TIED_VARS="path|fpath|manpath|cdpath|mailpath|infopath"
for f in functions/*.sh lib/profile/*.sh .zshenv .zprofile .zshrc; do
    if [ -f "$f" ]; then
        # `local path` — scoping issue: local scalar breaks the tie on function exit
        # `read -r path` — no local: sets global `path`, directly corrupting PATH
        if grep -Enq "(local[[:space:]]+|read[[:space:]]+-r[[:space:]]+)($ZSH_TIED_VARS)([[:space:]]|=|$)" "$f" 2>/dev/null; then
            grep -En "(local[[:space:]]+|read[[:space:]]+-r[[:space:]]+)($ZSH_TIED_VARS)([[:space:]]|=|$)" "$f"
            echo "$f: shadows a zsh tied array (path/fpath/etc.) — use a different variable name."
            errors=1
        fi
    fi
done

# Check for stat -f used directly in arithmetic expansion.
# BSD stat uses -f for format, but GNU coreutils stat uses -f for filesystem mode.
# If GNU stat is installed (e.g. via homebrew coreutils), it will return strings
# like `File: "/path"` instead of a timestamp, causing a math expression error.
# Always validate stat output is numeric before using it in arithmetic.
for f in functions/*.sh lib/profile/*.sh .zshenv .zprofile .zshrc; do
    if [ -f "$f" ]; then
        if grep -Enq '\$\(\(.*\$\(stat[[:space:]]+-f' "$f" 2>/dev/null; then
            grep -En '\$\(\(.*\$\(stat[[:space:]]+-f' "$f"
            echo "$f: stat -f used directly in arithmetic — validate output is numeric first (GNU coreutils stat returns strings, not timestamps)."
            errors=1
        fi
    fi
done

# Run profile system tests
if [ -f "tests/run.sh" ]; then
    echo "Running tests..."
    if ! /opt/homebrew/bin/zsh tests/run.sh; then
        echo ""
        echo "Tests failed."
        errors=1
    fi
fi

if [ "$errors" -ne 0 ]; then
    echo ""
    echo "Pre-commit checks failed. Fix the issues above before committing."
    exit 1
fi
