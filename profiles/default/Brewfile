tap "homebrew/autoupdate"

# Core CLI (macOS needs GNU tools; Linux has them natively)
if OS.mac?
    brew "coreutils"
    brew "grep"
    brew "rsync"
end
brew "jq"
brew "sevenzip"
brew "watch"
brew "wget"
brew "zsh"

# Dev tools
brew "act"              # Run GitHub Actions locally
brew "direnv"
brew "fzf"
brew "gdu"              # Disk usage analyzer
brew "gh"
brew "git"
brew "git-lfs"
brew "jj"               # Jujutsu VCS
brew "mise"
brew "shellcheck"
brew "trufflehog"       # Secret scanner

# Languages & runtimes
# req. for mise to build ruby@3
brew "libyaml"

# Database
brew "libpq"

# Containers & infrastructure
brew "docker"
brew "docker-buildx"
brew "docker-compose"

# Networking
brew "croc"             # File transfer
brew "fastly"
brew "mtr"              # Network diagnostics
brew "nmap"

# AI
brew "ollama", restart_service: :changed

# Media
brew "ffmpeg"
brew "yt-dlp"

# Dev tools (additional)
brew "lefthook"
brew "python@3.13"

# Casks (macOS only)
if OS.mac?
    cask "bruno"            # API client
    cask "claude-code"
    cask "iterm2"
    cask "lagrange"         # Gemini browser
    cask "orbstack"         # Docker/Linux VMs
    cask "qmk-toolbox"     # Keyboard firmware
    cask "visual-studio-code@insiders"
end
