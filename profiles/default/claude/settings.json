{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "alwaysThinkingEnabled": true,
  "cleanupPeriodDays": 365,
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "420000",
    "BASH_MAX_TIMEOUT_MS": "420000"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(touch:*)",
      "Bash(grep:*)",
      "Bash(rm:*)",
      "Bash(chmod:*)",
      "Bash(shasum:*)",
      "Bash(ioreg:*)",
      "Bash(xargs:*)",
      "Bash(source:*)",
      "Bash(export:*)",
      "Bash(printf:*)",
      "Bash(code-insiders:*)",
      "Bash(mise:*)",
      "Bash(brew:*)",
      "Bash(zsh:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(zig:*)",
      "Bash(desloppify:*)",
      "Bash(profile switch:*)",
      "Read(//Users/skooch/.claude/**)",
      "Read(//Users/skooch/.cache/zig/**)",
      "Read(//Users/skooch/.local/share/mise/**)",
      "Read(//private/etc/**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git push --force:*)",
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd:*)",
      "Bash(mkfs:*)",
      "Bash(mkfs *)",
      "Bash(dd:*)",
      "Bash(dd *)",
      "Bash(wget *|bash*)",
      "Bash(wget *| bash*)",
      "Bash(curl *|bash*)",
      "Bash(curl *| bash*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.npm/**)",
      "Read(~/.pypirc)",
      "Read(~/.gem/credentials)",
      "Read(~/Library/Keychains/**)",
      "Read(**/*credential*)",
      "Read(**/*secret*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.ssh/**)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(npm publish:*)",
      "Bash(eval:*)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true
  }
}
