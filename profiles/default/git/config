[user]
	name = skooch
	email = github@skooch.ws
[push]
	autoSetupRemote = true
[pull]
	rebase = true
[fetch]
	parallel = 0
	writeCommitGraph = true
[submodule]
	alternateLocation = superproject
	alternateErrorStrategy = info
	fetchJobs = 0
[gc]
	writeCommitGraph = true
[maintenance]
	strategy = incremental
[rerere]
	enabled = true
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[credential "http://127.0.0.1:1234"]
	helper = !~/projects/skooch/lib/git-cache/credential-helper.sh
[alias]
	cleanup = "!git branch --merged | grep  -v '\\*\\|master\\|develop\\|main' | xargs -n 1 -r git branch -d"
